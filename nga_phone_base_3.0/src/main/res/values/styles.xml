<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="AppTheme.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar"/>

    <style name="AppTheme.PopupOverlay" parent="ThemeOverlay.AppCompat.Light"/>

    <style name="AppThemeDayNight" parent="Theme.AppCompat.DayNight.DarkActionBar">
        <item name="android:textColor">@color/text_color_selector</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@color/window_background</item>
        <!-- target 35 起 Android 强制 edge-to-edge，statusBarColor 被忽略，导致状态栏露出窗口背景色。
             本项目仍 target 35，临时退出强制（升 target 36 前需改为真正的 insets 适配）。 -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement" tools:targetApi="35">true</item>
        <!-- 导航条透明并关闭系统对比度蒙层 -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="29">false</item>
    </style>


    <style name="AppThemeDayNightBrown" parent="@style/AppThemeDayNight">
        <item name="colorPrimary">@color/colorPrimaryBrown</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkBrown</item>
        <item name="colorAccent">@color/colorAccentBrown</item>
    </style>

    <style name="AppThemeDayNightBrown.NoActionBar" parent="@style/AppThemeDayNightBrown">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <style name="AppThemeDayNightGreen" parent="@style/AppThemeDayNight">
        <item name="colorPrimary">@color/colorPrimaryGreen</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkGreen</item>
        <item name="colorAccent">@color/colorAccentGreen</item>
    </style>

    <style name="AppThemeDayNightGreen.NoActionBar" parent="@style/AppThemeDayNightGreen">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>


    <style name="AppThemeDayNightBlack" parent="@style/AppThemeDayNight">
        <item name="colorPrimary">@color/colorPrimaryBlack</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkBlack</item>
        <item name="colorAccent">@color/colorAccentBlack</item>
    </style>

    <style name="AppThemeDayNightBlack.NoActionBar" parent="@style/AppThemeDayNightBlack">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.AboutActivity" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/material_window_background</item>
        <item name="mal_card_background">@color/material_card_background</item>
        <item name="mal_toolbarTheme">@style/Theme.Mal.Toolbar.Dark</item>
        <item name="mal_toolbarPopupTheme">@style/Theme.Mal.Toolbar.Light</item>
        <item name="mal_color_primary">@color/material_title_color</item>
        <item name="mal_color_secondary">@color/material_sub_title_color</item>
    </style>

    <style name="Theme.AboutActivity.Green" parent="Theme.AboutActivity">
        <item name="colorPrimary">@color/colorPrimaryGreen</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkGreen</item>
        <item name="colorAccent">@color/colorAccentGreen</item>
    </style>

    <!-- 默认主题 -->
    <style name="Theme.AboutActivity.Brown" parent="Theme.AboutActivity">
        <item name="colorPrimary">@color/colorPrimaryBrown</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkBrown</item>
        <item name="colorAccent">@color/colorAccentBrown</item>
    </style>

    <style name="Theme.AboutActivity.Black" parent="Theme.AboutActivity">
        <item name="colorPrimary">@color/colorPrimaryBlack</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDarkBlack</item>
        <item name="colorAccent">@color/colorAccentBlack</item>
    </style>


</resources>